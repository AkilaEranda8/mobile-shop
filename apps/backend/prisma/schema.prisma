}

// ─────────────── Delivery / Courier / Tracking ───────────────

enum DeliveryStatus {
  PENDING
  PACKED
  AWAITING_TRACKING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum TrackingNumberStatus {
  AVAILABLE
  ASSIGNED
  USED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

model Courier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String
  logoUrl   String?
  website   String?
  phone     String?
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trackingPool   TrackingNumber[]
  deliveryOrders DeliveryOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model TrackingNumber {
  id              String               @id @default(cuid())
  tenantId        String
  courierId       String
  number          String
  status          TrackingNumberStatus @default(AVAILABLE)
  assignedAt      DateTime?
  deliveryOrderId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  courier       Courier        @relation(fields: [courierId], references: [id], onDelete: Cascade)
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId, courierId, status])
}

model DeliveryOrder {
  id          String  @id @default(cuid())
  tenantId    String
  branchId    String?
  orderNumber String

  customerName  String
  customerPhone String
  customerEmail String?

  addressLine1 String
  addressLine2 String?
  city         String
  district     String?
  postalCode   String?

  subtotal       Float   @default(0)
  deliveryCharge Float   @default(0)
  totalAmount    Float   @default(0)
  codAmount      Float?
  isCOD          Boolean @default(false)

  courierId      String?
  trackingNumber String?

  status       DeliveryStatus @default(PENDING)
  notes        String?
  createdById  String?
  dispatchedAt DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courier         Courier?               @relation(fields: [courierId], references: [id])
  items           DeliveryItem[]
  waybills        Waybill[]
  notifications   DeliveryNotification[]
  trackingNumbers TrackingNumber[]
  sale            Sale?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

model DeliveryItem {
  id              String @id @default(cuid())
  deliveryOrderId String
  description     String
  quantity        Int    @default(1)
  unitPrice       Float  @default(0)
  total           Float  @default(0)

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
}

model Waybill {
  id              String    @id @default(cuid())
  tenantId        String
  deliveryOrderId String
  waybillNumber   String
  reprintCount    Int       @default(0)
  printedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deliveryOrderId])
}

model DeliveryNotification {
  id              String             @id @default(cuid())
  tenantId        String
  deliveryOrderId String
  channel         String             @default("whatsapp")
  phone           String
  message         String
  status          NotificationStatus @default(PENDING)
  errorMessage    String?
  sentAt          DateTime?
  retryCount      Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deliveryOrderId])
}

// ─────────────── Platform Config ───────────────
model PlatformConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────── Support Notes ───────────────
model SupportNote {
  id        String   @id @default(cuid())
  tenantId  String
  note      String
  adminName String   @default("Support Admin")
  ticketRef String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─────────────── Daily Reload ───────────────

model DailyReload {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  connectionNo  String
  provider      String?
  transactionId String?
  executedBy    String?
  reloadDate    DateTime @default(now())
  status        String   @default("Success")
  reloadType    String   @default("RELOAD")
  amount        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([tenantId, reloadDate])
  @@index([tenantId, branchId, reloadDate])
}

model DailyReloadProviderPayment {
  id            String        @id @default(cuid())
  tenantId      String
  branchId      String
  provider      String
  businessDate  DateTime      @db.Date
  reloadTotal   Float
  commission    Float
  amountPaid    Float
  paymentMethod PaymentMethod @default(CASH)
  paidBy        String
  financeTxId   String?
  createdAt     DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@index([tenantId, businessDate])
}

// ─────────────── Daily Closing ───────────────

enum DailyClosingStatus {
  DRAFT
  CLOSED
}

model DailyClosing {
  id       String             @id @default(cuid())
  tenantId String
  branchId String
  date     DateTime           @db.Date
  status   DailyClosingStatus @default(DRAFT)

  totalSales        Float @default(0)
  mobileSales       Float @default(0)
  accessorySales    Float @default(0)
  serviceIncome     Float @default(0)
  repairIncome      Float @default(0)
  billPaymentIncome Float @default(0)
  reloadSales       Float @default(0)
  otherIncome       Float @default(0)

  grossSales       Float @default(0)
  cogs             Float @default(0)
  grossProfit      Float @default(0)
  reloadCommission Float @default(0)
  netProfit        Float @default(0)
  totalExpenses    Float @default(0)

  openingCash    Float @default(0)
  cashSales      Float @default(0)
  bankDeposits   Float @default(0)
  qrPayments     Float @default(0)
  cardPayments   Float @default(0)
  expectedCash   Float @default(0)
  actualCash     Float @default(0)
  cashVariance   Float @default(0)
  cashInBank     Float @default(0)
  closingBalance Float @default(0)

  mobilesSold         Int @default(0)
  imeisRegistered     Int @default(0)
  pendingImeis        Int @default(0)
  warrantiesActivated Int @default(0)
  salesCount          Int @default(0)
  newCustomers        Int @default(0)
  repairsCompleted    Int @default(0)

  summaryJson      Json?
  expenseBreakdown Json?
  reloadBreakdown  Json?
  insightsJson     Json?
  notes            String?

  closedBy     String?
  closedByName String?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch                 @relation(fields: [branchId], references: [id])
  cashCount DailyClosingCashCount?
  reports   DailyClosingReport[]

  @@unique([tenantId, branchId, date])
  @@index([tenantId, date])
}

model DailyClosingCashCount {
  id        String @id @default(cuid())
  closingId String @unique
  d5000     Int    @default(0)
  d2000     Int    @default(0)
  d1000     Int    @default(0)
  d500      Int    @default(0)
  d100      Int    @default(0)
  d50       Int    @default(0)
  d20       Int    @default(0)
  d10       Int    @default(0)
  d5        Int    @default(0)
  d2        Int    @default(0)
  d1        Int    @default(0)
  coins     Float  @default(0)
  total     Float  @default(0)

  closing DailyClosing @relation(fields: [closingId], references: [id], onDelete: Cascade)
}

model DailyClosingReport {
  id          String   @id @default(cuid())
  closingId   String
  reportType  String
  format      String   @default("PDF")
  generatedBy String?
  generatedAt DateTime @default(now())

  closing DailyClosing @relation(fields: [closingId], references: [id], onDelete: Cascade)

  @@index([closingId])
}

// ─────────────── Platform Activity Logs ───────────────
model PlatformActivityLog {
  id        String   @id @default(cuid())
  eventType String
  severity  String   @default("INFO")
  actorType String
  actor     String
  target    String   @default("—")
  details   String
  ip        String   @default("—")
  tenantId  String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
}

// ─────────────── Profit Allocation & Fund Management ───────────────

model ProfitFund {
  id          String         @id @default(cuid())
  tenantId    String
  branchId    String
  name        String
  type        ProfitFundType
  fixedAmount Float          @default(0)
  percentage  Float          @default(0)
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)
  description String?
  balance     Float          @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch                 @relation(fields: [branchId], references: [id])
  allocationLines ProfitAllocationLine[]
  transactions    ProfitTransaction[]
  withdrawals     ProfitWithdrawal[]

  @@unique([tenantId, branchId, name])
  @@index([tenantId, branchId])
}

model ProfitAllocation {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String
  date            DateTime
  todaySales      Float    @default(0)
  todayProfit     Float    @default(0)
  totalAllocated  Float    @default(0)
  remainingProfit Float    @default(0)
  notes           String?
  createdBy       String?
  createdByName   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch                 @relation(fields: [branchId], references: [id])
  lines  ProfitAllocationLine[]

  @@unique([tenantId, branchId, date])
  @@index([tenantId, date])
}

model ProfitAllocationLine {
  id               String @id @default(cuid())
  allocationId     String
  fundId           String
  todayAllocation  Float  @default(0)
  yesterdayBalance Float  @default(0)
  totalBalance     Float  @default(0)
  withdrawn        Float  @default(0)
  remainingBalance Float  @default(0)

  allocation ProfitAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  fund       ProfitFund       @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([allocationId, fundId])
}

model ProfitTransaction {
  id           String        @id @default(cuid())
  tenantId     String
  branchId     String
  fundId       String
  date         DateTime
  type         ProfitTxnType
  amount       Float
  balanceAfter Float         @default(0)
  notes        String?
  userId       String?
  userName     String?
  createdAt    DateTime      @default(now())

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch     @relation(fields: [branchId], references: [id])
  fund   ProfitFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId, date])
  @@index([fundId])
}

model ProfitWithdrawal {
  id        String        @id @default(cuid())
  tenantId  String
  branchId  String
  fundId    String
  type      ProfitTxnType
  amount    Float
  notes     String?
  userId    String?
  userName  String?
  createdAt DateTime      @default(now())

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch     @relation(fields: [branchId], references: [id])
  fund   ProfitFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([tenantId, fundId])
  @@index([tenantId, branchId])
}

// ─────────────── Platform Announcements ───────────────
model PlatformAnnouncement {
  id            String    @id @default(cuid())
  title         String
  body          String
  type          String    @default("INFO")
  status        String    @default("DRAFT")
  target        String    @default("ALL")
  targetTenants String[]  @default([])
  dismissible   Boolean   @default(true)
  scheduledAt   DateTime?
  sentAt        DateTime?
  seenCount     Int       @default(0)
  createdBy     String    @default("Admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  dismissals AnnouncementDismissal[]
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  userId         String
  announcementId String
  dismissedAt    DateTime @default(now())

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement PlatformAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@index([userId])
  @@index([announcementId])
}

// ─────────────── Release Notes ───────────────
model Release {
  id             String   @id @default(cuid())
  version        String
  title          String
  summary        String
  releaseDate    DateTime
  status         String   @default("DRAFT")
  popupEnabled   Boolean  @default(true)
  active         Boolean  @default(true)
  targetType     String   @default("ALL")
  targetPlans    String[] @default([])
  targetTenants  String[] @default([])
  targetBranches String[] @default([])
  imageUrl       String?
  videoUrl       String?
  docUrl         String?
  createdBy      String   @default("Admin")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items ReleaseItem[]
  reads TenantReleaseRead[]

  @@index([status, releaseDate])
  @@index([version])
}

model ReleaseItem {
  id           String  @id @default(cuid())
  releaseId    String
  category     String
  module       String?
  featureName  String
  description  String
  badge        String?
  displayOrder Int     @default(0)
  imageUrl     String?
  videoUrl     String?
  docUrl       String?

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@index([releaseId, displayOrder])
}

model TenantReleaseRead {
  id        String    @id @default(cuid())
  tenantId  String
  releaseId String
  isRead    Boolean   @default(false)
  readAt    DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([tenantId, releaseId])
  @@index([tenantId])
  @@index([releaseId])
}

// ─────────────── Accounting Module ───────────────

enum GlAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum GlAccountSubtype {
  CASH
  BANK
  AR
  AP
  INVENTORY
  TAX_INPUT
  TAX_OUTPUT
  PAYROLL
  REVENUE
  COGS
  OPEX
  CASH_VARIANCE
  CONTRA_REVENUE
  EQUITY
  RETAINED
  OTHER
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  REVERSED
}

enum JournalSourceModule {
  MANUAL
  SALES
  PURCHASE
  REPAIR
  EXPENSE
  AR
  AP
  CASH_BANK
  PETTY_CASH
  PAYROLL
  TAX
  PERIOD_CLOSE
  DAILY_CLOSING
}

enum AccountingPeriodStatus {
  OPEN
  SOFT_CLOSED
  HARD_CLOSED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaxCodeType {
  OUTPUT
  INPUT
}

model AccountingSettings {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  baseCurrency         String    @default("LKR")
  fiscalYearStartMonth Int       @default(1)
  autoPostEnabled      Boolean   @default(true)
  /// When true, repair auto-journals split inclusive 18% VAT to VAT Output Payable.
  /// Sales still use the tax amount on the sale (0 = no VAT line).
  vatEnabled           Boolean   @default(false)
  requireApprovalAbove Float?
  initializedAt        DateTime?
  defaultAccounts      Json      @default("{}")
  expenseCategoryMap   Json      @default("{}")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AccountingPeriod {
  id        String                 @id @default(cuid())
  tenantId  String
  name      String
  startDate DateTime               @db.Date
  endDate   DateTime               @db.Date
  status    AccountingPeriodStatus @default(OPEN)
  closedBy  String?
  closedAt  DateTime?
  createdAt DateTime               @default(now())

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
}

model GlAccount {
  id               String           @id @default(cuid())
  tenantId         String
  branchId         String?
  code             String
  name             String
  type             GlAccountType
  subtype          GlAccountSubtype @default(OTHER)
  parentAccountId  String?
  isControlAccount Boolean          @default(false)
  isActive         Boolean          @default(true)
  isSystem         Boolean          @default(false)
  description      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation(fields: [branchId], references: [id])
  parentAccount GlAccount?    @relation("GlAccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts GlAccount[]   @relation("GlAccountHierarchy")
  journalLines  JournalLine[]
  taxCodes      TaxCode[]
  cashAccounts  CashAccount[]
  bankAccounts  BankAccount[]

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([tenantId, branchId])
}

model JournalEntry {
  id             String              @id @default(cuid())
  tenantId       String
  branchId       String?
  periodId       String
  entryNo        String
  entryDate      DateTime            @db.Date
  sourceModule   JournalSourceModule @default(MANUAL)
  sourceRefType  String?
  sourceRefId    String?
  sourceEvent    String?
  memo           String?
  status         JournalStatus       @default(DRAFT)
  totalDebit     Float               @default(0)
  totalCredit    Float               @default(0)
  reversalOfId   String?
  createdById    String?
  createdByEmail String?
  approvedById   String?
  approvedAt     DateTime?
  postedAt       DateTime?
  postedById     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch?           @relation(fields: [branchId], references: [id])
  period           AccountingPeriod  @relation(fields: [periodId], references: [id])
  lines            JournalLine[]
  integrationLinks IntegrationLink[]

  @@unique([tenantId, entryNo])
  @@unique([tenantId, sourceRefType, sourceRefId, sourceEvent])
  @@index([tenantId, entryDate, status])
  @@index([tenantId, branchId, entryDate])
}

model JournalLine {
  id          String   @id @default(cuid())
  entryId     String
  tenantId    String
  branchId    String?
  lineNo      Int
  accountId   String
  description String?
  debit       Float    @default(0)
  credit      Float    @default(0)
  taxCodeId   String?
  customerId  String?
  supplierId  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account GlAccount    @relation(fields: [accountId], references: [id])
  taxCode TaxCode?     @relation(fields: [taxCodeId], references: [id])

  @@index([tenantId, accountId])
  @@index([entryId])
}

model AccountingOutbox {
  id          String       @id @default(cuid())
  tenantId    String
  branchId    String?
  sourceType  String
  sourceId    String
  eventType   String
  payload     Json?
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@unique([tenantId, sourceType, sourceId, eventType])
  @@index([status, createdAt])
}

model IntegrationLink {
  id             String   @id @default(cuid())
  tenantId       String
  sourceType     String
  sourceId       String
  eventType      String
  journalEntryId String
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sourceType, sourceId, eventType])
  @@index([journalEntryId])
}

model AutoJournalRule {
  id                String              @id @default(cuid())
  tenantId          String
  branchId          String?
  sourceModule      JournalSourceModule
  eventType         String
  name              String
  enabled           Boolean             @default(true)
  priority          Int                 @default(100)
  conditionsJson    Json?
  linesTemplateJson Json
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([tenantId, eventType, enabled])
}

model CashAccount {
  id          String  @id @default(cuid())
  tenantId    String
  branchId    String
  name        String
  glAccountId String
  isActive    Boolean @default(true)

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch    @relation(fields: [branchId], references: [id])
  glAccount GlAccount @relation(fields: [glAccountId], references: [id])

  @@unique([tenantId, branchId, name])
}

enum BankAccountType {
  CURRENT
  SAVINGS
}

model BankAccount {
  id          String          @id @default(cuid())
  tenantId    String
  branchId    String?
  name        String
  accountNo   String?
  bankName    String?
  accountType BankAccountType @default(CURRENT)
  glAccountId String
  isActive    Boolean         @default(true)

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch?   @relation(fields: [branchId], references: [id])
  glAccount GlAccount @relation(fields: [glAccountId], references: [id])
  transactions Transaction[]

  @@unique([tenantId, name])
}

model TaxCode {
  id          String      @id @default(cuid())
  tenantId    String
  code        String
  name        String
  rate        Float
  type        TaxCodeType
  glAccountId String
  isActive    Boolean     @default(true)

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  glAccount    GlAccount     @relation(fields: [glAccountId], references: [id])
  journalLines JournalLine[]

  @@unique([tenantId, code])
}

model AuditEvent {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  actorUserId String?
  actorEmail  String
  eventType   String
  entityType  String
  entityId    String
  beforeJson  Json?
  afterJson   Json?
  ip          String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
}

model ApprovalRequest {
  id            String         @id @default(cuid())
  tenantId      String
  branchId      String?
  entityType    String
  entityId      String
  action        String
  status        ApprovalStatus @default(PENDING)
  requestedById String?
  requestedBy   String
  approvedById  String?
  approvedBy    String?
  reason        String?
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

// ── Feature Suggestions ──────────────────────────────────────────────────────

enum FeatureSuggestionStatus {
  NEW
  UNDER_REVIEW
  PLANNED
  IN_PROGRESS
  RELEASED
  DECLINED
}

enum FeatureSuggestionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FeatureSuggestionHistoryAction {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  RESPONSE_UPDATED
  RELEASED
  DECLINED
}

enum UserNotificationType {
  FEATURE_SUGGESTION
  SYSTEM
  LICENSE
  ANNOUNCEMENT
  SUBSCRIPTION
  BUG_REPORT
}

model FeatureSuggestion {
  id                String                     @id @default(cuid())
  tenantId          String
  submittedById     String
  category          String
  title             String
  description       String
  status            FeatureSuggestionStatus    @default(NEW)
  priority          FeatureSuggestionPriority  @default(MEDIUM)
  publicResponse    String?
  internalNote      String?
  respondedByEmail  String?
  respondedAt       DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  tenant      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submittedBy User                        @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  history     FeatureSuggestionHistory[]

  @@index([tenantId])
  @@index([submittedById])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
  @@index([tenantId, submittedById, createdAt])
  @@index([status, priority, createdAt])
  @@index([tenantId, status, createdAt])
}

/// Append-only audit trail. Application code never updates/deletes rows.
/// Cascade from parent suggestion exists only so tenant cleanup can remove orphans.
model FeatureSuggestionHistory {
  id               String                          @id @default(cuid())
  suggestionId     String
  action           FeatureSuggestionHistoryAction
  oldStatus        FeatureSuggestionStatus?
  newStatus        FeatureSuggestionStatus?
  oldPriority      FeatureSuggestionPriority?
  newPriority      FeatureSuggestionPriority?
  publicResponse   String?
  performedByEmail String
  createdAt        DateTime                        @default(now())

  suggestion FeatureSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@index([suggestionId])
  @@index([createdAt])
  @@index([suggestionId, createdAt])
}

/// Persistent per-user notifications reusable by future modules.
model UserNotification {
  id        String               @id @default(cuid())
  tenantId  String
  userId    String
  type      UserNotificationType
  title     String
  message   String
  link      String?
  relatedId String?
  isRead    Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([relatedId])
}
