generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────── Enums ───────────────

enum UserRole {
  PLATFORM_ADMIN
  OWNER
  MANAGER
  CASHIER
  TECHNICIAN
}

enum SubscriptionPlan {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum RepairStatus {
  RECEIVED
  DIAGNOSED
  IN_REPAIR
  QC
  READY
  DELIVERED
  CANCELLED
}

enum RepairPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CLAIMED
  VOID
}

enum WarrantyClaimType {
  SOFTWARE
  HARDWARE
}

enum WarrantyClaimStatus {
  OPEN
  ASSESSED
  IN_REPAIR
  RESOLVED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CLOSED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  WALLET
  CREDIT
}

enum SaleStatus {
  PAID
  PARTIAL
  DUE
  RETURNED
}

enum StockMovementType {
  PURCHASE
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  REPAIR_USE
  RETURN
}

enum ImeiStatus {
  IN_STOCK
  SOLD
  IN_REPAIR
  UNDER_WARRANTY_CLAIM
  SCRAPPED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ProfitFundType {
  FIXED_AMOUNT
  PERCENTAGE
  MANUAL
}

enum ProfitTxnType {
  ALLOCATION
  WITHDRAW
  DEPOSIT
  ADJUSTMENT
}

// ─────────────── Tenant / Auth ───────────────

model Tenant {
  id                  String           @id @default(cuid())
  name                String
  slug                String           @unique
  plan                SubscriptionPlan @default(TRIAL)
  status              TenantStatus     @default(TRIAL)
  trialEndsAt         DateTime?
  subscriptionEndsAt  DateTime?
  ownerEmail          String
  ownerName           String
  mrr                 Float            @default(0)
  invoiceSettings     Json?
  reloadSettings      Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  branches    Branch[]
  users       User[]
  categories  Category[]
  brands      Brand[]
  products    Product[]
  customers   Customer[]
  sales       Sale[]
  repairs     RepairTicket[]
  warranties  Warranty[]
  deviceBrands DeviceBrand[]
  deviceModels DeviceModel[]
  suppliers   Supplier[]
  purchaseOrders PurchaseOrder[]
  transactions   Transaction[]
  dailySummaries DailySummary[]
  whatsAppConfig  WhatsAppConfig?
  couriers        Courier[]
  deliveryOrders  DeliveryOrder[]
  supportNotes    SupportNote[]
  saleReturns     SaleReturn[]
  exchanges       DeviceExchange[]
  features        TenantFeature[]
  services        Service[]
  dailyReloads    DailyReload[]
  dailyReloadProviderPayments DailyReloadProviderPayment[]
  dailyClosings   DailyClosing[]
  profitFunds     ProfitFund[]
  profitAllocations ProfitAllocation[]
  profitTransactions ProfitTransaction[]
  profitWithdrawals  ProfitWithdrawal[]
}

model TenantFeature {
  id        String   @id @default(cuid())
  tenantId  String
  feature   String
  enabled   Boolean  @default(true)
  price     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, feature])
}

model Service {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  cost        Float    @default(0)
  price       Float
  category    String   @default("General")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Branch {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  address         String
  city            String
  state           String
  phone           String
  email           String?
  isHeadquarters  Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users    UserBranch[]
  products Product[]
  sales    Sale[]
  repairs  RepairTicket[]
  purchaseOrders PurchaseOrder[]
  transactions   Transaction[]
  stockMovements StockMovement[]
  dailySummaries DailySummary[]
  dailyClosings  DailyClosing[]
  profitFunds    ProfitFund[]
  profitAllocations ProfitAllocation[]
  dailyReloadProviderPayments DailyReloadProviderPayment[]
  profitTransactions ProfitTransaction[]
  profitWithdrawals  ProfitWithdrawal[]
  imeiRecords    ImeiRecord[]
  exchanges      DeviceExchange[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  name      String
  password  String
  role      UserRole @default(CASHIER)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches       UserBranch[]
  salesAssCashier Sale[]     @relation("SaleCashier")
  repairs        RepairTicket[] @relation("RepairTechnician")
  refreshTokens  RefreshToken[]

  @@unique([tenantId, email])
}

model UserBranch {
  userId   String
  branchId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────── Inventory ───────────────

model Category {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  slug         String
  icon         String?
  productCount Int      @default(0)
  createdAt    DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, slug])
}

model Brand {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  logoUrl      String?
  productCount Int      @default(0)
  createdAt    DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
}

model Product {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String
  name            String
  sku             String
  barcode         String?
  categoryId      String
  brandId         String
  description     String?
  buyingPrice     Float
  sellingPrice    Float
  mrp             Float
  trackImei       Boolean  @default(false)
  warrantyMonths  Int      @default(0)
  imageUrl        String?
  stock           Int      @default(0)
  minStock        Int      @default(5)
  isActive        Boolean  @default(true)
  storageVariations Json?
  colorVariations   Json?
  subCategory       String?
  deviceModel       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch    @relation(fields: [branchId], references: [id])
  category  Category  @relation(fields: [categoryId], references: [id])
  brand     Brand     @relation(fields: [brandId], references: [id])
  imeiRecords    ImeiRecord[]
  stockMovements StockMovement[]
  saleItems      SaleItem[]
  returnItems    SaleReturnItem[]
  repairParts    RepairSparePart[]
  poItems        POItem[]
  warranties     Warranty[]

  @@unique([tenantId, sku])
}

model ImeiRecord {
  id          String     @id @default(cuid())
  imei        String     @unique
  productId   String
  branchId    String
  customerId  String?
  saleId      String?
  purchaseOrderId String?
  poItemId        String?
  status      ImeiStatus @default(IN_STOCK)
  variation   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  product  Product   @relation(fields: [productId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  sale     Sale?     @relation(fields: [saleId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  branchId    String
  type        StockMovementType
  quantity    Int
  reference   String?
  note        String?
  performedBy String
  createdAt   DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
}

// ─────────────── Customer ───────────────

model Customer {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  phone          String
  email          String?
  address        String?
  city           String?
  loyaltyPoints  Int      @default(0)
  totalPurchases Int      @default(0)
  totalDue       Float    @default(0)
  totalRepairs   Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales       Sale[]
  repairs     RepairTicket[]
  warranties  Warranty[]
  imeiRecords ImeiRecord[]
  exchanges   DeviceExchange[]

  @@unique([tenantId, phone])
}

// ─────────────── POS / Sale ───────────────

model Sale {
  id              String     @id @default(cuid())
  tenantId        String
  branchId        String?
  invoiceNumber   String
  customerId      String?
  customerName    String?
  customerPhone   String?
  subtotal        Float
  discount        Float      @default(0)
  tax             Float      @default(0)
  total           Float
  paidAmount      Float
  dueAmount       Float      @default(0)
  status          SaleStatus @default(PAID)
  cashierId       String?
  cashierName     String
  source          String     @default("POS")
  deliveryOrderId String?    @unique
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  cashier       User?          @relation("SaleCashier", fields: [cashierId], references: [id])
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])
  items         SaleItem[]
  payments      SalePayment[]
  returns       SaleReturn[]
  imeiRecords   ImeiRecord[]

  @@unique([tenantId, invoiceNumber])
}

model SaleItem {
  id             String  @id @default(cuid())
  saleId         String
  productId      String?
  productName    String
  sku            String  @default("")
  imei           String?
  quantity       Int
  unitPrice      Float
  discount       Float   @default(0)
  total          Float
  warrantyMonths Int     @default(0)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model SalePayment {
  id        String        @id @default(cuid())
  saleId    String
  method    PaymentMethod
  amount    Float
  reference String?

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model SaleReturn {
  id           String           @id @default(cuid())
  tenantId     String
  branchId     String?
  saleId       String
  returnNumber String
  reason       String
  refundAmount Float
  refundMethod PaymentMethod
  processedBy  String
  notes        String?
  createdAt    DateTime         @default(now())

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   Sale             @relation(fields: [saleId], references: [id])
  items  SaleReturnItem[]

  @@unique([tenantId, returnNumber])
}

model SaleReturnItem {
  id          String  @id @default(cuid())
  returnId    String
  productId   String?
  productName String
  quantity    Int
  unitPrice   Float
  total       Float

  return  SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id])
}

// ─────────────── Device Catalog ───────────────

model DeviceBrand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  models DeviceModel[]

  @@unique([tenantId, name])
}

model DeviceModel {
  id        String   @id @default(cuid())
  tenantId  String
  brandId   String
  brandName String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand  DeviceBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([tenantId, brandId, name])
}

// ─────────────── Repair ───────────────

model RepairTicket {
  id                  String         @id @default(cuid())
  tenantId            String
  branchId            String
  ticketNumber        String
  customerId          String
  customerName        String
  customerPhone       String
  deviceBrand         String
  deviceModel         String
  deviceColor         String?
  imei                String?
  accessories         String?
  reportedIssue       String
  estimatedCost       Float
  actualCost          Float?
  status              RepairStatus   @default(RECEIVED)
  priority            RepairPriority @default(NORMAL)
  technicianId        String?
  technicianName      String?
  source              String         @default("WALK_IN")
  photos              String[]
  estimatedCompletion DateTime?
  completedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch          @relation(fields: [branchId], references: [id])
  customer   Customer        @relation(fields: [customerId], references: [id])
  technician User?           @relation("RepairTechnician", fields: [technicianId], references: [id])
  notes      RepairNote[]
  spareParts RepairSparePart[]
  history    RepairStatusHistory[]

  @@unique([tenantId, ticketNumber])
}

model RepairNote {
  id         String   @id @default(cuid())
  repairId   String
  text       String
  authorName String
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())

  repair RepairTicket @relation(fields: [repairId], references: [id], onDelete: Cascade)
}

model RepairSparePart {
  id          String @id @default(cuid())
  repairId    String
  productId   String
  productName String
  quantity    Int
  unitCost    Float
  total       Float

  repair  RepairTicket @relation(fields: [repairId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
}

model RepairStatusHistory {
  id         String       @id @default(cuid())
  repairId   String
  status     RepairStatus
  changedBy  String
  note       String?
  timestamp  DateTime     @default(now())

  repair RepairTicket @relation(fields: [repairId], references: [id], onDelete: Cascade)
}

// ─────────────── Device Exchange ───────────────

model DeviceExchange {
  id             String   @id @default(cuid())
  tenantId       String
  branchId       String
  exchangeNumber String
  customerId     String?
  customerName   String
  customerPhone  String
  oldBrand       String
  oldModel       String
  oldImei        String?
  oldCondition   String   @default("GOOD")
  exchangeValue  Float    @default(0)
  newBrand       String?
  newModel       String?
  newImei        String?
  newDevicePrice Float?
  saleId         String?
  notes          String?
  status         String   @default("COMPLETED")
  createdBy      String   @default("system")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch    @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([tenantId, exchangeNumber])
}

// ─────────────── Warranty ───────────────

model Warranty {
  id             String         @id @default(cuid())
  tenantId       String
  warrantyCode   String         @unique
  saleId         String?
  invoiceNumber  String?
  customerId     String?
  customerName   String
  customerPhone  String
  productId      String?
  productName    String
  brandName      String
  imei           String?
  startDate      DateTime
  endDate        DateTime
  monthsDuration Int
  status         WarrantyStatus @default(ACTIVE)
  qrUrl          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer?       @relation(fields: [customerId], references: [id])
  product  Product?        @relation(fields: [productId], references: [id])
  claims   WarrantyClaim[]
}

model WarrantyClaim {
  id              String              @id @default(cuid())
  warrantyId      String
  issue           String
  claimType       WarrantyClaimType   @default(HARDWARE)
  status          WarrantyClaimStatus @default(OPEN)
  repairTicketId  String?
  assessedBy      String?
  resolution      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  warranty Warranty @relation(fields: [warrantyId], references: [id], onDelete: Cascade)
}

// ─────────────── Supplier ───────────────

model Supplier {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  contactName         String
  phone               String
  email               String?
  address             String?
  city                String?
  gstin               String?
  totalOrders         Int      @default(0)
  totalPurchaseValue  Float    @default(0)
  outstandingDues     Float    @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  tenantId         String
  branchId         String
  poNumber         String
  supplierId       String
  supplierName     String
  status           PurchaseOrderStatus @default(DRAFT)
  subtotal         Float
  tax              Float               @default(0)
  total            Float
  paidAmount       Float               @default(0)
  dueAmount        Float
  expectedDelivery DateTime?
  receivedAt       DateTime?
  imeisRegisteredAt DateTime?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  items    POItem[]
  imeiRecords ImeiRecord[]

  @@unique([tenantId, poNumber])
}

model POItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  productId        String?
  productName      String
  quantity         Int
  receivedQuantity Int     @default(0)
  unitCost         Float
  total            Float
  storage          String?
  colorName        String?
  sku              String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])
}

// ─────────────── Finance ───────────────

model Transaction {
  id            String          @id @default(cuid())
  tenantId      String
  branchId      String
  type          TransactionType
  category      String
  amount        Float
  description   String
  paymentMethod PaymentMethod
  reference     String?
  performedBy   String
  createdAt     DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])
}

model DailySummary {
  id                String   @id @default(cuid())
  tenantId          String
  branchId          String
  date              DateTime @db.Date
  totalSales        Int      @default(0)
  totalRevenue      Float    @default(0)
  totalExpenses     Float    @default(0)
  profit            Float    @default(0)
  repairsCompleted  Int      @default(0)
  newCustomers      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([tenantId, branchId, date])
}

// ─────────────── WhatsApp Integration ───────────────

model WhatsAppConfig {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  accessToken      String
  phoneNumberId    String
  wabaId           String
  verifyToken      String
  enabled          Boolean   @default(false)
  autoSendInvoice  Boolean   @default(false)
  sendPdfInvoice   Boolean   @default(false)
  validatePhones   Boolean   @default(true)
  invoiceTemplate  String    @default("")
  status           String    @default("disconnected")
  phoneNumber      String?
  displayName      String?
  qualityRating    String?
  lastCheckedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]
}

model WhatsAppMessage {
  id           String   @id @default(cuid())
  tenantId     String
  configId     String
  orderId      String?
  to           String
  customerName String?
  type         String
  preview      String
  status       String   @default("sent")
  metaMessageId String?
  amount       Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  config WhatsAppConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([configId])
}

// ─────────────── Delivery / Courier / Tracking ───────────────

enum DeliveryStatus {
  PENDING
  PACKED
  AWAITING_TRACKING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum TrackingNumberStatus {
  AVAILABLE
  ASSIGNED
  USED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

model Courier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  logoUrl     String?
  website     String?
  phone       String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trackingPool   TrackingNumber[]
  deliveryOrders DeliveryOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model TrackingNumber {
  id              String               @id @default(cuid())
  tenantId        String
  courierId       String
  number          String
  status          TrackingNumberStatus @default(AVAILABLE)
  assignedAt      DateTime?
  deliveryOrderId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  courier       Courier        @relation(fields: [courierId], references: [id], onDelete: Cascade)
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])

  @@unique([tenantId, number])
  @@index([tenantId, courierId, status])
}

model DeliveryOrder {
  id             String         @id @default(cuid())
  tenantId       String
  branchId       String?
  orderNumber    String

  customerName   String
  customerPhone  String
  customerEmail  String?

  addressLine1   String
  addressLine2   String?
  city           String
  district       String?
  postalCode     String?

  subtotal       Float          @default(0)
  deliveryCharge Float          @default(0)
  totalAmount    Float          @default(0)
  codAmount      Float?
  isCOD          Boolean        @default(false)

  courierId      String?
  trackingNumber String?

  status         DeliveryStatus @default(PENDING)
  notes          String?
  createdById    String?
  dispatchedAt   DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courier        Courier?              @relation(fields: [courierId], references: [id])
  items          DeliveryItem[]
  waybills       Waybill[]
  notifications  DeliveryNotification[]
  trackingNumbers TrackingNumber[]
  sale           Sale?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

model DeliveryItem {
  id              String  @id @default(cuid())
  deliveryOrderId String
  description     String
  quantity        Int     @default(1)
  unitPrice       Float   @default(0)
  total           Float   @default(0)

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
}

model Waybill {
  id              String   @id @default(cuid())
  tenantId        String
  deliveryOrderId String
  waybillNumber   String
  reprintCount    Int      @default(0)
  printedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deliveryOrderId])
}

model DeliveryNotification {
  id              String             @id @default(cuid())
  tenantId        String
  deliveryOrderId String
  channel         String             @default("whatsapp")
  phone           String
  message         String
  status          NotificationStatus @default(PENDING)
  errorMessage    String?
  sentAt          DateTime?
  retryCount      Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deliveryOrderId])
}

// ─────────────── Platform Config ───────────────
model PlatformConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────── Support Notes ───────────────
model SupportNote {
  id        String   @id @default(cuid())
  tenantId  String
  note      String
  adminName String   @default("Support Admin")
  ticketRef String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─────────────── Daily Reload ───────────────

model DailyReload {
  id            String   @id @default(cuid())
  tenantId      String
  connectionNo  String
  provider      String?
  transactionId String?
  executedBy    String?
  reloadDate    DateTime @default(now())
  status        String   @default("Success")
  reloadType    String   @default("RELOAD")
  amount        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, reloadDate])
}

model DailyReloadProviderPayment {
  id            String        @id @default(cuid())
  tenantId      String
  branchId      String
  provider      String
  businessDate  DateTime      @db.Date
  reloadTotal   Float
  commission    Float
  amountPaid    Float
  paymentMethod PaymentMethod @default(CASH)
  paidBy        String
  financeTxId   String?
  createdAt     DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@index([tenantId, businessDate])
}

// ─────────────── Daily Closing ───────────────

enum DailyClosingStatus {
  DRAFT
  CLOSED
}

model DailyClosing {
  id                  String             @id @default(cuid())
  tenantId            String
  branchId            String
  date                DateTime           @db.Date
  status              DailyClosingStatus @default(DRAFT)

  totalSales          Float @default(0)
  mobileSales         Float @default(0)
  accessorySales      Float @default(0)
  serviceIncome       Float @default(0)
  repairIncome        Float @default(0)
  billPaymentIncome   Float @default(0)
  reloadSales         Float @default(0)
  otherIncome         Float @default(0)

  grossSales          Float @default(0)
  cogs                Float @default(0)
  grossProfit         Float @default(0)
  reloadCommission    Float @default(0)
  netProfit           Float @default(0)
  totalExpenses       Float @default(0)

  openingCash         Float @default(0)
  cashSales           Float @default(0)
  bankDeposits        Float @default(0)
  qrPayments          Float @default(0)
  cardPayments        Float @default(0)
  expectedCash        Float @default(0)
  actualCash          Float @default(0)
  cashVariance        Float @default(0)
  cashInBank          Float @default(0)
  closingBalance      Float @default(0)

  mobilesSold         Int @default(0)
  imeisRegistered     Int @default(0)
  pendingImeis        Int @default(0)
  warrantiesActivated Int @default(0)
  salesCount          Int @default(0)
  newCustomers        Int @default(0)
  repairsCompleted    Int @default(0)

  summaryJson         Json?
  expenseBreakdown    Json?
  reloadBreakdown     Json?
  insightsJson        Json?
  notes               String?

  closedBy            String?
  closedByName        String?
  closedAt            DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch                  @relation(fields: [branchId], references: [id])
  cashCount DailyClosingCashCount?
  reports   DailyClosingReport[]

  @@unique([tenantId, branchId, date])
  @@index([tenantId, date])
}

model DailyClosingCashCount {
  id        String @id @default(cuid())
  closingId String @unique
  d5000     Int    @default(0)
  d2000     Int    @default(0)
  d1000     Int    @default(0)
  d500      Int    @default(0)
  d100      Int    @default(0)
  d50       Int    @default(0)
  d20       Int    @default(0)
  d10       Int    @default(0)
  coins     Float  @default(0)
  total     Float  @default(0)

  closing DailyClosing @relation(fields: [closingId], references: [id], onDelete: Cascade)
}

model DailyClosingReport {
  id          String   @id @default(cuid())
  closingId   String
  reportType  String
  format      String   @default("PDF")
  generatedBy String?
  generatedAt DateTime @default(now())

  closing DailyClosing @relation(fields: [closingId], references: [id], onDelete: Cascade)

  @@index([closingId])
}

// ─────────────── Platform Activity Logs ───────────────
model PlatformActivityLog {
  id        String   @id @default(cuid())
  eventType String
  severity  String   @default("INFO")
  actorType String
  actor     String
  target    String   @default("—")
  details   String
  ip        String   @default("—")
  tenantId  String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
}

// ─────────────── Profit Allocation & Fund Management ───────────────

model ProfitFund {
  id          String         @id @default(cuid())
  tenantId    String
  branchId    String
  name        String
  type        ProfitFundType
  fixedAmount Float          @default(0)
  percentage  Float          @default(0)
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)
  description String?
  balance     Float          @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch                 @relation(fields: [branchId], references: [id])
  allocationLines ProfitAllocationLine[]
  transactions ProfitTransaction[]
  withdrawals  ProfitWithdrawal[]

  @@unique([tenantId, branchId, name])
  @@index([tenantId, branchId])
}

model ProfitAllocation {
  id               String   @id @default(cuid())
  tenantId         String
  branchId         String
  date             DateTime
  todaySales       Float    @default(0)
  todayProfit      Float    @default(0)
  totalAllocated   Float    @default(0)
  remainingProfit  Float    @default(0)
  notes            String?
  createdBy        String?
  createdByName    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch                 @relation(fields: [branchId], references: [id])
  lines  ProfitAllocationLine[]

  @@unique([tenantId, branchId, date])
  @@index([tenantId, date])
}

model ProfitAllocationLine {
  id               String @id @default(cuid())
  allocationId     String
  fundId           String
  todayAllocation  Float  @default(0)
  yesterdayBalance Float  @default(0)
  totalBalance     Float  @default(0)
  withdrawn        Float  @default(0)
  remainingBalance Float  @default(0)

  allocation ProfitAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  fund       ProfitFund       @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([allocationId, fundId])
}

model ProfitTransaction {
  id           String        @id @default(cuid())
  tenantId     String
  branchId     String
  fundId       String
  date         DateTime
  type         ProfitTxnType
  amount       Float
  balanceAfter Float         @default(0)
  notes        String?
  userId       String?
  userName     String?
  createdAt    DateTime      @default(now())

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch     @relation(fields: [branchId], references: [id])
  fund   ProfitFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId, date])
  @@index([fundId])
}

model ProfitWithdrawal {
  id        String        @id @default(cuid())
  tenantId  String
  branchId  String
  fundId    String
  type      ProfitTxnType
  amount    Float
  notes     String?
  userId    String?
  userName  String?
  createdAt DateTime      @default(now())

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch     @relation(fields: [branchId], references: [id])
  fund   ProfitFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([tenantId, fundId])
  @@index([tenantId, branchId])
}

// ─────────────── Platform Announcements ───────────────
model PlatformAnnouncement {
  id          String    @id @default(cuid())
  title       String
  body        String
  type        String    @default("INFO")
  status      String    @default("DRAFT")
  target      String    @default("ALL")
  scheduledAt DateTime?
  sentAt      DateTime?
  seenCount   Int       @default(0)
  createdBy   String    @default("Admin")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
