generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────── Enums ───────────────

enum UserRole {
  PLATFORM_ADMIN
  OWNER
  MANAGER
  CASHIER
  TECHNICIAN
}

enum SubscriptionPlan {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum RepairStatus {
  RECEIVED
  DIAGNOSED
  IN_REPAIR
  QC
  READY
  DELIVERED
  CANCELLED
}

enum RepairPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  CLAIMED
  VOID
}

enum WarrantyClaimType {
  SOFTWARE
  HARDWARE
}

enum WarrantyClaimStatus {
  OPEN
  ASSESSED
  IN_REPAIR
  RESOLVED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CLOSED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  WALLET
  CREDIT
}

enum SaleStatus {
  PAID
  PARTIAL
  DUE
  RETURNED
}

enum StockMovementType {
  PURCHASE
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  REPAIR_USE
  RETURN
  EXCHANGE_IN
}

enum ImeiStatus {
  IN_STOCK
  SOLD
  IN_REPAIR
  UNDER_WARRANTY_CLAIM
  SCRAPPED
}

enum ProductCondition {
  BRAND_NEW
  USED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum ProfitFundType {
  FIXED_AMOUNT
  PERCENTAGE
  MANUAL
}

enum ProfitTxnType {
  ALLOCATION
  WITHDRAW
  DEPOSIT
  ADJUSTMENT
}

// ─────────────── Tenant / Auth ───────────────

model Tenant {
  id                     String           @id @default(cuid())
  name                   String
  slug                   String           @unique
  plan                   SubscriptionPlan @default(TRIAL)
  status                 TenantStatus     @default(TRIAL)
  trialEndsAt            DateTime?
  subscriptionEndsAt     DateTime?
  ownerEmail             String
  ownerName              String
  mrr                    Float            @default(0)
  invoiceSettings        Json?
  reloadSettings         Json?
  productVariantSettings Json?
  productCodeSettings    Json?
  paymentMethodSettings  Json?
  posUiSettings          Json?
  /// Owner-managed role x module access: hide | view | edit
  rolePermissions        Json?
  /// Demo catalog installed from templates (not permanent business data)
  demoDataInstalled      Boolean          @default(false)
  /// IDs created by demo installer — used only for clean removal
  demoDataManifest       Json?
  demoDataClearedAt      DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  branches                    Branch[]
  users                       User[]
  categories                  Category[]
  brands                      Brand[]
  products                    Product[]
  customers                   Customer[]
  sales                       Sale[]
  repairs                     RepairTicket[]
  warranties                  Warranty[]
  deviceBrands                DeviceBrand[]
  deviceModels                DeviceModel[]
  suppliers                   Supplier[]
  purchaseOrders              PurchaseOrder[]
  transactions                Transaction[]
  dailySummaries              DailySummary[]
  whatsAppConfig              WhatsAppConfig?
  couriers                    Courier[]
  deliveryOrders              DeliveryOrder[]
  supportNotes                SupportNote[]
  saleReturns                 SaleReturn[]
  exchanges                   DeviceExchange[]
  features                    TenantFeature[]
  services                    Service[]
  dailyReloads                DailyReload[]
  dailyReloadProviderPayments DailyReloadProviderPayment[]
  dailyClosings               DailyClosing[]
  profitFunds                 ProfitFund[]
  profitAllocations           ProfitAllocation[]
  profitTransactions          ProfitTransaction[]
  profitWithdrawals           ProfitWithdrawal[]
  releaseReads                TenantReleaseRead[]
  accountingSettings          AccountingSettings?
  accountingPeriods           AccountingPeriod[]
  glAccounts                  GlAccount[]
  journalEntries              JournalEntry[]
  accountingOutbox            AccountingOutbox[]
  autoJournalRules            AutoJournalRule[]
  auditEvents                 AuditEvent[]
  approvalRequests            ApprovalRequest[]
  cashAccounts                CashAccount[]
  bankAccounts                BankAccount[]
  taxCodes                    TaxCode[]
  repairFaultOptions          RepairFaultOption[]
  featureSuggestions          FeatureSuggestion[]
  userNotifications           UserNotification[]
}

model TenantFeature {
  id        String   @id @default(cuid())
  tenantId  String
  feature   String
  enabled   Boolean  @default(true)
  price     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, feature])
}

model Service {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  cost        Float    @default(0)
  price       Float
  category    String   @default("General")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Branch {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  address        String
  city           String
  state          String
  phone          String
  email          String?
  isHeadquarters Boolean  @default(false)
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users                       UserBranch[]
  products                    Product[]
  sales                       Sale[]
  repairs                     RepairTicket[]
  purchaseOrders              PurchaseOrder[]
  transactions                Transaction[]
  stockMovements              StockMovement[]
  dailySummaries              DailySummary[]
  dailyClosings               DailyClosing[]
  profitFunds                 ProfitFund[]
  profitAllocations           ProfitAllocation[]
  dailyReloadProviderPayments DailyReloadProviderPayment[]
  dailyReloads                DailyReload[]
  profitTransactions          ProfitTransaction[]
  profitWithdrawals           ProfitWithdrawal[]
  imeiRecords                 ImeiRecord[]
  exchanges                   DeviceExchange[]
  customers                   Customer[]
  warranties                  Warranty[]
  glAccounts                  GlAccount[]
  journalEntries              JournalEntry[]
  cashAccounts                CashAccount[]
  bankAccounts                BankAccount[]
  accountingOutbox            AccountingOutbox[]
  autoJournalRules            AutoJournalRule[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  name      String
  password  String
  role      UserRole @default(CASHIER)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches               UserBranch[]
  salesAssCashier        Sale[]                  @relation("SaleCashier")
  repairs                RepairTicket[]          @relation("RepairTechnician")
  refreshTokens          RefreshToken[]
  announcementDismissals AnnouncementDismissal[]
  featureSuggestions     FeatureSuggestion[]
  userNotifications      UserNotification[]

  @@unique([tenantId, email])
}

model UserBranch {
  userId   String
  branchId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────── Inventory ───────────────

model Category {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  slug         String
  icon         String?
  productCount Int      @default(0)
  createdAt    DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, slug])
}

model Brand {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  logoUrl      String?
  productCount Int      @default(0)
  createdAt    DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
}

model Product {
  id                String           @id @default(cuid())
  tenantId          String
  branchId          String
  name              String
  sku               String
  barcode           String?
  categoryId        String
  brandId           String
  description       String?
  buyingPrice       Float
  sellingPrice      Float
  wholesalePrice    Float            @default(0)
  creditPrice       Float            @default(0)
  mrp               Float
  trackImei         Boolean          @default(false)
  warrantyMonths    Int              @default(0)
  warrantyNote      String?
  imageUrl          String?
  stock             Int              @default(0)
  minStock          Int              @default(5)
  isActive          Boolean          @default(true)
  storageVariations Json?
  colorVariations   Json?
  subCategory       String?
  deviceModel       String?
  condition         ProductCondition @default(BRAND_NEW)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch            @relation(fields: [branchId], references: [id])
  category       Category          @relation(fields: [categoryId], references: [id])
  brand          Brand             @relation(fields: [brandId], references: [id])
  imeiRecords    ImeiRecord[]
  stockMovements StockMovement[]
  saleItems      SaleItem[]
  returnItems    SaleReturnItem[]
  repairParts    RepairSparePart[]
  poItems        POItem[]
  warranties     Warranty[]

  @@unique([tenantId, sku])
}

model ImeiRecord {
  id              String     @id @default(cuid())
  imei            String     @unique
  productId       String
  branchId        String
  customerId      String?
  saleId          String?
  purchaseOrderId String?
  poItemId        String?
  status          ImeiStatus @default(IN_STOCK)
  variation       String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  product       Product        @relation(fields: [productId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  sale          Sale?          @relation(fields: [saleId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  branchId    String
  type        StockMovementType
  quantity    Int
  reference   String?
  note        String?
  performedBy String
  createdAt   DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])
}

// ─────────────── Customer ───────────────

model Customer {
  id             String   @id @default(cuid())
  tenantId       String
  /// Home branch — listed only for this branch (or All Branches)
  branchId       String?
  name           String
  phone          String
  email          String?
  address        String?
  city           String?
  loyaltyPoints  Int      @default(0)
  totalPurchases Int      @default(0)
  totalDue       Float    @default(0)
  totalRepairs   Int      @default(0)
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  sales       Sale[]
  repairs     RepairTicket[]
  warranties  Warranty[]
  imeiRecords ImeiRecord[]
  exchanges   DeviceExchange[]

  @@unique([tenantId, branchId, phone])
  @@index([tenantId, branchId])
  @@index([tenantId, isActive])
}

// ─────────────── POS / Sale ───────────────

model Sale {
  id              String     @id @default(cuid())
  tenantId        String
  branchId        String?
  invoiceNumber   String
  customerId      String?
  customerName    String?
  customerPhone   String?
  subtotal        Float
  discount        Float      @default(0)
  tax             Float      @default(0)
  total           Float
  paidAmount      Float
  dueAmount       Float      @default(0)
  status          SaleStatus @default(PAID)
  cashierId       String?
  cashierName     String
  source          String     @default("POS")
  deliveryOrderId String?    @unique
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  cashier       User?          @relation("SaleCashier", fields: [cashierId], references: [id])
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])
  items         SaleItem[]
  payments      SalePayment[]
  returns       SaleReturn[]
  imeiRecords   ImeiRecord[]

  @@unique([tenantId, invoiceNumber])
}

model SaleItem {
  id             String  @id @default(cuid())
  saleId         String
  productId      String?
  productName    String
  sku            String  @default("")
  imei           String?
  quantity       Int
  unitPrice      Float
  unitCost       Float   @default(0)
  discount       Float   @default(0)
  total          Float
  warrantyMonths Int     @default(0)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model SalePayment {
  id        String        @id @default(cuid())
  saleId    String
  method    PaymentMethod
  amount    Float
  reference String?

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model SaleReturn {
  id           String        @id @default(cuid())
  tenantId     String
  branchId     String?
  saleId       String
  returnNumber String
  reason       String
  refundAmount Float
  refundMethod PaymentMethod
  processedBy  String
  notes        String?
  createdAt    DateTime      @default(now())

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   Sale             @relation(fields: [saleId], references: [id])
  items  SaleReturnItem[]

  @@unique([tenantId, returnNumber])
}

model SaleReturnItem {
  id          String  @id @default(cuid())
  returnId    String
  productId   String?
  productName String
  quantity    Int
  unitPrice   Float
  total       Float

  return  SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id])
}

// ─────────────── Device Catalog ───────────────

model DeviceBrand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  models DeviceModel[]

  @@unique([tenantId, name])
}

model DeviceModel {
  id        String   @id @default(cuid())
  tenantId  String
  brandId   String
  brandName String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand  DeviceBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([tenantId, brandId, name])
}

// ─────────────── Master Catalog (global, Super Admin only) ───────────────

enum MasterCatalogBrandType {
  PHONE
  ACCESSORY
  BOTH
}

model MasterCatalogCategory {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  phoneModels MasterCatalogPhoneModel[]
  accessories MasterCatalogAccessory[]
}

model MasterCatalogBrand {
  id           String                 @id @default(cuid())
  name         String                 @unique
  type         MasterCatalogBrandType @default(BOTH)
  displayOrder Int                    @default(0)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  phoneModels MasterCatalogPhoneModel[]
  accessories MasterCatalogAccessory[]
}

model MasterCatalogPhoneModel {
  id                    String   @id @default(cuid())
  brandId               String
  categoryId            String
  name                  String
  releaseYear           Int?
  displayOrder          Int      @default(0)
  isActive              Boolean  @default(true)
  trackImei             Boolean  @default(true)
  defaultWarrantyMonths Int      @default(12)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  brand    MasterCatalogBrand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category MasterCatalogCategory       @relation(fields: [categoryId], references: [id])
  variants MasterCatalogPhoneVariant[]

  @@unique([brandId, name])
}

model MasterCatalogPhoneVariant {
  id           String   @id @default(cuid())
  modelId      String
  storage      String
  colorName    String
  colorHex     String?
  skuSuffix    String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  model MasterCatalogPhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, storage, colorName])
}

model MasterCatalogAccessory {
  id            String   @id @default(cuid())
  categoryId    String
  brandId       String?
  name          String
  modelOptional String?
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category MasterCatalogCategory @relation(fields: [categoryId], references: [id])
  brand    MasterCatalogBrand?   @relation(fields: [brandId], references: [id])

  @@unique([categoryId, name, brandId])
}

// ─────────────── Repair ───────────────

model RepairTicket {
  id                  String         @id @default(cuid())
  tenantId            String
  branchId            String
  ticketNumber        String
  customerId          String
  customerName        String
  customerPhone       String
  deviceBrand         String
  deviceModel         String
  deviceColor         String?
  imei                String?
  accessories         String?
  deviceCondition     String?
  reportedIssue       String
  estimatedCost       Float
  actualCost          Float?
  paidAmount          Float?
  dueAmount           Float?
  status              RepairStatus   @default(RECEIVED)
  priority            RepairPriority @default(NORMAL)
  technicianId        String?
  technicianName      String?
  source              String         @default("WALK_IN")
  photos              String[]
  estimatedCompletion DateTime?
  completedAt         DateTime?
  warrantyMonths      Int?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch                @relation(fields: [branchId], references: [id])
  customer   Customer              @relation(fields: [customerId], references: [id])
  technician User?                 @relation("RepairTechnician", fields: [technicianId], references: [id])
  notes      RepairNote[]
  spareParts RepairSparePart[]
  history    RepairStatusHistory[]

  @@unique([tenantId, ticketNumber])
}

model RepairNote {
  id         String   @id @default(cuid())
  repairId   String
  text       String
  authorName String
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())

  repair RepairTicket @relation(fields: [repairId], references: [id], onDelete: Cascade)
}

model RepairSparePart {
  id             String  @id @default(cuid())
  repairId       String
  productId      String
  productName    String
  quantity       Int
  unitCost       Float
  unitBuyCost    Float   @default(0)
  warrantyMonths Int     @default(0)
  warrantyNote   String?
  total          Float

  repair  RepairTicket @relation(fields: [repairId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
}

model RepairStatusHistory {
  id        String       @id @default(cuid())
  repairId  String
  status    RepairStatus
  changedBy String
  note      String?
  timestamp DateTime     @default(now())

  repair RepairTicket @relation(fields: [repairId], references: [id], onDelete: Cascade)
}

model RepairFaultOption {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─────────────── Device Exchange ───────────────

model DeviceExchange {
  id                  String   @id @default(cuid())
  tenantId            String
  branchId            String
  exchangeNumber      String
  customerId          String?
  customerName        String
  customerPhone       String
  customerAddress     String?
  oldProductName      String?
  oldBrand            String
  oldModel            String
  oldImei             String?
  oldColor            String?
  oldStorage          String?
  oldCondition        String   @default("GOOD")
  exchangeValue       Float    @default(0)
  oldProductId        String?
  tradeInImeiRecordId String?
  newBrand            String?
  newModel            String?
  newImei             String?
  newColor            String?
  newStorage          String?
  newDevicePrice      Float?
  soldProductId       String?
  soldVariation       String?
  balanceAmount       Float?
  balanceDirection    String?
  invoiceNumber       String?
  saleId              String?
  notes               String?
  status              String   @default("COMPLETED")
  createdBy           String   @default("system")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch    @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([tenantId, exchangeNumber])
}

// ─────────────── Warranty ───────────────

model Warranty {
  id             String         @id @default(cuid())
  tenantId       String
  branchId       String?
  warrantyCode   String         @unique
  saleId         String?
  invoiceNumber  String?
  customerId     String?
  customerName   String
  customerPhone  String
  productId      String?
  productName    String
  brandName      String
  imei           String?
  quantity       Int            @default(1)
  startDate      DateTime
  endDate        DateTime
  monthsDuration Int
  status         WarrantyStatus @default(ACTIVE)
  qrUrl          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer Customer?       @relation(fields: [customerId], references: [id])
  product  Product?        @relation(fields: [productId], references: [id])
  claims   WarrantyClaim[]

  @@index([tenantId, branchId])
}

model WarrantyClaim {
  id             String              @id @default(cuid())
  warrantyId     String
  issue          String
  claimType      WarrantyClaimType   @default(HARDWARE)
  status         WarrantyClaimStatus @default(OPEN)
  repairTicketId String?
  assessedBy     String?
  resolution     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  warranty Warranty @relation(fields: [warrantyId], references: [id], onDelete: Cascade)
}

// ─────────────── Supplier ───────────────

model Supplier {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  contactName        String
  phone              String
  email              String?
  address            String?
  city               String?
  gstin              String?
  totalOrders        Int      @default(0)
  totalPurchaseValue Float    @default(0)
  outstandingDues    Float    @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  transactions   Transaction[]
}

model PurchaseOrder {
  id                String              @id @default(cuid())
  tenantId          String
  branchId          String
  poNumber          String
  supplierId        String
  supplierName      String
  status            PurchaseOrderStatus @default(DRAFT)
  subtotal          Float
  tax               Float               @default(0)
  total             Float
  paidAmount        Float               @default(0)
  dueAmount         Float
  expectedDelivery  DateTime?
  receivedAt        DateTime?
  imeisRegisteredAt DateTime?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id])
  supplier     Supplier      @relation(fields: [supplierId], references: [id])
  items        POItem[]
  imeiRecords  ImeiRecord[]
  transactions Transaction[]
  paymentAllocations SupplierPaymentAllocation[]

  @@unique([tenantId, poNumber])
}

model POItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  productId        String?
  productName      String
  quantity         Int
  receivedQuantity Int     @default(0)
  unitCost         Float
  total            Float
  storage          String?
  colorName        String?
  sku              String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])
}

// ─────────────── Finance ───────────────

model Transaction {
  id              String          @id @default(cuid())
  tenantId        String
  branchId        String
  type            TransactionType
  category        String
  amount          Float
  description     String
  paymentMethod   PaymentMethod
  reference       String?
  /// Optional Cash & Bank register used for BANK_TRANSFER / cheque supplier payments
  bankAccountId   String?
  /// Business date of the payment/expense (defaults to createdAt when null)
  occurredAt      DateTime?
  /// Linked supplier for Supplier Payment category rows
  supplierId      String?
  /// Primary purchase order / invoice this payment was applied to (optional)
  purchaseOrderId String?
  performedBy     String
  createdAt       DateTime        @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch         @relation(fields: [branchId], references: [id])
  bankAccount   BankAccount?   @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  supplierPaymentAllocations SupplierPaymentAllocation[]

  @@index([tenantId, bankAccountId])
  @@index([tenantId, category, createdAt])
  @@index([tenantId, supplierId])
}

model SupplierPaymentAllocation {
  id              String   @id @default(cuid())
  tenantId        String
  transactionId   String
  purchaseOrderId String
  amount          Float
  createdAt       DateTime @default(now())

  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)

  @@unique([transactionId, purchaseOrderId])
  @@index([tenantId, purchaseOrderId])
  @@index([tenantId, transactionId])
}

model DailySummary {
  id               String   @id @default(cuid())
  tenantId         String
  branchId         String
  date             DateTime @db.Date
  totalSales       Int      @default(0)
  totalRevenue     Float    @default(0)
  totalExpenses    Float    @default(0)
  profit           Float    @default(0)
  repairsCompleted Int      @default(0)
  newCustomers     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([tenantId, branchId, date])
}

// ─────────────── WhatsApp Integration ───────────────

model WhatsAppConfig {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  connectionMode  String    @default("qr")
  accessToken     String    @default("")
  phoneNumberId   String    @default("")
  wabaId          String    @default("")
  verifyToken     String    @default("")
  enabled         Boolean   @default(false)
  autoSendInvoice Boolean   @default(false)
  sendPdfInvoice  Boolean   @default(false)
  validatePhones  Boolean   @default(true)
  invoiceTemplate String    @default("")
  status          String    @default("disconnected")
  phoneNumber     String?
  displayName     String?
  qualityRating   String?
  lastCheckedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]
}

model WhatsAppMessage {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  configId      String
  orderId       String?
  to            String
  customerName  String?
  type          String
  preview       String
  status        String   @default("sent")
