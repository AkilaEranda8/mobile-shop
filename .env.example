# ============================================
# HEXALYTE - Environment Variables
# ============================================
# Copy to `.env` in the repo root (same folder as docker-compose.yml).
# NEVER commit `.env`. Generate strong values for production.
#
#   cp .env.example .env
#   chmod 600 .env   # Linux/macOS
#
# Docker Compose substitutes ${VAR} from this file.

# ---- Database ----
POSTGRES_USER=hexalyte
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=hexalyte
# Hostnames `postgres` / `redis` are Docker service names.
DATABASE_URL=postgresql://hexalyte:CHANGE_ME_strong_db_password@postgres:5432/hexalyte

# ---- Redis ----
# If password has special characters (@ # : /), URL-encode them in REDIS_URL.
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379

# ---- JWT / NextAuth ----
# Use long random strings (32+ chars). Rotate independently of Keycloak.
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars_xxxxxxxx
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret_min_32_chars_xxxx
NEXTAUTH_URL=https://app.hexalyte.com

# ---- Keycloak ----
KEYCLOAK_URL=https://auth.hexalyte.com
KC_REALM=hexalyte
KC_CLIENT_ID=hexalyte-backend
KC_CLIENT_SECRET=CHANGE_ME_keycloak_client_secret
KEYCLOAK_AUTH_ENABLED=true
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.hexalyte.com

# ---- App ----
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://app.hexalyte.com
BACKEND_URL=https://api.shop.hexalyte.com
API_PREFIX=api/v1
NEXT_PUBLIC_API_URL=https://api.shop.hexalyte.com/api/v1
NEXT_PUBLIC_ADMIN_API_URL=https://api.shop.hexalyte.com/admin/v1
NEXT_PUBLIC_WEB_URL=https://app.hexalyte.com
NEXT_PUBLIC_APP_URL=https://app.hexalyte.com

# Bootstrap first platform admin only when none exist (leave empty on prod if already bootstrapped)
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=

# ---- AWS S3 ----
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=hexalyte-storage
AWS_S3_ENDPOINT=

# ---- Email (SMTP) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Hexalyte <noreply@hexalyte.com>

# ---- Deploy (local machine only — never commit) ----
# HEXALYTE_SSH_HOST=157.180.113.249
# HEXALYTE_SSH_USER=root
# HEXALYTE_SSH_PASS=
# HEXALYTE_SSH_HOSTKEY=SHA256:...
